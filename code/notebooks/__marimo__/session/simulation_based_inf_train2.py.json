          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><span class=\"paragraph\">cond_np_all = build_cond_np(stimd, delayd, side, t1, t2, t3, t4)\ntheta_true_free = prior.sample((1,)).numpy().astype(np.float32)[0]</span>\n<span class=\"paragraph\">theta_full_1 = np.tile(TEMPLATE_THETA_FULL[None,:], (1,1)).astype(np.float32)\ntheta_full_1[:, FREE_TO_FULL] = theta_true_free[None,:]\ntheta_true_full = theta_full_1[0].astype(np.float32)</span>\n<span class=\"paragraph\">N = stimd.shape[0]\ntheta_full_trials = np.tile(theta_true_full[None,:], (N,1)).astype(np.float32)</span>\n<span class=\"paragraph\">choice_obs = get_choices_varying_numba(\n    stimd.astype(np.float32),\n    delayd.astype(np.float32),\n    side.astype(np.float32),\n    t1.astype(np.float32),\n    t2.astype(np.float32),\n    t3.astype(np.float32),\n    t4.astype(np.float32),\n    theta_full_trials,\n    DT, TH1, TH2, TH3\n).astype(np.int16)</span>\n<span class=\"paragraph\">_ok = (choice_obs != -1)\ncond_np_ok = cond_np_all[_ok]\nchoice_obs_ok = choice_obs[_ok].astype(np.int64)</span>\n<span class=\"paragraph\">print(\"Observed ok trials:\", int(_ok.sum()), \"/\", int(N), \"miss_rate:\", float((~_ok).mean()))</span>\n<span class=\"paragraph\">def bads_objective(theta_free):\n    theta_free = np.asarray(theta_free, dtype=np.float32)\n    return mlp_nll_for_theta(mlp, theta_free, cond_np_ok, choice_obs_ok, chunk=200000)</span>\n<h1 id=\"-bounds-\">--- bounds ---</h1>\n<span class=\"paragraph\">lb  = np.array([-3.0, -3.0,  0.0,  -3.0,  0.0], dtype=float)\nub  = np.array([ 3.0,  3.0,  3.0,   3.0,  10.0], dtype=float)\nplb = np.array([-1.0, -1.0,  0.05, -1.0,  0.1], dtype=float)\npub = np.array([ 1.0,  1.0,  2.0,   1.0,  5.0], dtype=float)</span>\n<span class=\"paragraph\">x0 = theta_true_free + 0.2<em>np.random.randn(</em>theta_true_free.shape).astype(np.float32)</span>\n<span class=\"paragraph\">bads = BADS(\n    fun=bads_objective,\n    x0=x0,\n    lower_bounds=lb, upper_bounds=ub,\n    plausible_lower_bounds=plb, plausible_upper_bounds=pub,\n    options={\"display\": \"iter\", \"uncertainty_handling\": False},\n)\nres = bads.optimize()</span>\n<span class=\"paragraph\">print(\"\\n--- RECOVERY ---\")\nprint(\"theta_true_free:\", theta_true_free)\nprint(\"theta_hat_free :\", res.x)\nprint(\"abs error      :\", np.abs(res.x - theta_true_free))\nprint(\"NLL_hat        :\", res.fval)</span></span>"
